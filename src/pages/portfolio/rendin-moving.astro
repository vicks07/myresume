---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { profile } from '../../data/site';

const assetBase = `${import.meta.env.BASE_URL}/`.replace(/\/+$/, '/');
---

<Layout
	title="Rendin × Moving — Product Case Study | Vikram Thalithaje"
	description="A product opportunity analysis: how Rendin could use its move-in date signal to add a moving referral layer and close the tenant journey."
>
	<style>
		/* ── Case study shell ── */
		.cs-shell {
			position: relative;
			max-width: 1060px;
			margin: 0 auto;
			padding: 24px;
		}

		/* ── Topbar ── */
		.cs-topbar {
			position: sticky;
			top: 20px;
			z-index: 10;
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 20px;
			padding: 14px 18px;
			margin-bottom: 28px;
			background: rgba(255, 248, 239, 0.72);
			border: 1px solid rgba(255, 255, 255, 0.55);
			border-radius: 999px;
			backdrop-filter: blur(18px);
			box-shadow: 0 12px 40px rgba(45, 32, 22, 0.08);
		}

		.cs-brand {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-weight: 700;
			text-decoration: none;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			font-size: 0.85rem;
			color: var(--text);
		}

		.cs-nav {
			display: flex;
			gap: 18px;
			flex-wrap: wrap;
		}

		.cs-nav a {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.88rem;
			color: var(--muted);
			text-decoration: none;
		}

		.cs-nav a:hover { color: var(--text); }

		.cs-back {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.82rem;
			color: var(--muted);
			text-decoration: none;
			letter-spacing: 0.04em;
		}

		.cs-back:hover { color: var(--accent); }

		/* ── Hero ── */
		.cs-hero {
			padding: 48px 40px 44px;
			margin-bottom: 0;
		}

		.cs-hero-tag {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.75rem;
			text-transform: uppercase;
			letter-spacing: 0.11em;
			color: var(--accent-strong);
			margin: 0 0 20px;
		}

		.cs-hero h1 {
			font-size: clamp(2.6rem, 5.5vw, 5rem);
			line-height: 0.95;
			letter-spacing: -0.04em;
			margin: 0 0 20px;
			max-width: 700px;
		}

		.cs-hero h1 em {
			font-style: italic;
			color: var(--accent);
		}

		.cs-hero-sub {
			font-size: 1.08rem;
			color: var(--muted);
			line-height: 1.7;
			max-width: 640px;
			margin: 0 0 36px;
		}

		.cs-meta {
			display: flex;
			flex-wrap: wrap;
			gap: 28px;
		}

		.cs-meta-item {
			display: flex;
			flex-direction: column;
			gap: 3px;
		}

		.cs-meta-label {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.7rem;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: var(--muted);
		}

		.cs-meta-value {
			font-size: 0.95rem;
			font-weight: 600;
			color: var(--text);
		}

		/* ── Sections ── */
		.cs-section {
			padding: 52px 40px;
		}

		.cs-section-num {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.7rem;
			text-transform: uppercase;
			letter-spacing: 0.11em;
			color: var(--muted);
			margin: 0 0 14px;
		}

		.cs-section h2 {
			font-size: clamp(2rem, 4vw, 3.4rem);
			line-height: 0.98;
			letter-spacing: -0.03em;
			margin: 0 0 28px;
		}

		.cs-section h2 em {
			font-style: italic;
			color: var(--accent);
		}

		.cs-section p {
			font-size: 1.04rem;
			line-height: 1.72;
			color: var(--muted);
			margin: 0 0 18px;
		}

		.cs-section p strong {
			color: var(--text);
			font-weight: 600;
		}

		.cs-section p:last-child { margin-bottom: 0; }

		/* ── Callout ── */
		.callout {
			background: var(--panel-strong);
			border-left: 3px solid var(--accent);
			border-radius: 0 16px 16px 0;
			padding: 22px 26px;
			margin: 28px 0;
		}

		.callout-label {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.7rem;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: var(--accent-strong);
			margin: 0 0 8px;
		}

		.callout p {
			font-size: 1rem;
			color: var(--text);
			margin: 0;
		}

		/* ── Card grids ── */
		.card-grid {
			display: grid;
			gap: 16px;
			margin: 28px 0;
		}

		.card-grid-3 { grid-template-columns: repeat(3, 1fr); }
		.card-grid-2 { grid-template-columns: repeat(2, 1fr); }

		.cs-card {
			background: var(--panel-strong);
			border: 1px solid rgba(31, 35, 48, 0.08);
			border-radius: 20px;
			padding: 22px;
		}

		.cs-card-icon {
			font-size: 22px;
			margin-bottom: 12px;
		}

		.cs-card h4 {
			font-size: 1.1rem;
			margin: 0 0 8px;
			color: var(--text);
		}

		.cs-card p {
			font-size: 0.9rem;
			color: var(--muted);
			margin: 0;
			line-height: 1.55;
		}

		/* ── Personas ── */
		.persona {
			display: grid;
			grid-template-columns: 72px 1fr;
			gap: 22px;
			align-items: start;
			background: var(--panel-strong);
			border: 1px solid rgba(31, 35, 48, 0.08);
			border-radius: 20px;
			padding: 26px;
			margin-bottom: 16px;
		}

		.persona-avatar {
			width: 72px;
			height: 72px;
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 28px;
			flex-shrink: 0;
		}

		.persona-content h4 {
			font-size: 1.25rem;
			margin: 0 0 3px;
		}

		.persona-role {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.78rem;
			color: var(--muted);
			letter-spacing: 0.04em;
			margin-bottom: 14px;
		}

		.persona-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 8px;
			margin-bottom: 14px;
		}

		.ptag {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.7rem;
			padding: 4px 10px;
			border-radius: 999px;
			letter-spacing: 0.04em;
		}

		.ptag-pain {
			background: rgba(195, 88, 36, 0.12);
			color: #8a3e12;
		}

		.ptag-need {
			background: rgba(12, 124, 120, 0.12);
			color: var(--accent-strong);
		}

		.ptag-ctx {
			background: rgba(31, 35, 48, 0.07);
			color: var(--muted);
		}

		.persona-quote {
			font-style: italic;
			font-size: 0.96rem;
			color: var(--muted);
			border-left: 2px solid rgba(31, 35, 48, 0.14);
			padding-left: 16px;
			margin-top: 14px;
		}

		/* ── Stat boxes ── */
		.stat-row {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 16px;
			margin: 28px 0;
		}

		.cs-stat {
			background: var(--text);
			color: #f4efe7;
			padding: 26px 22px;
			border-radius: 20px;
		}

		.cs-stat-num {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 2.2rem;
			font-weight: 700;
			display: block;
			margin-bottom: 6px;
		}

		.cs-stat-label {
			font-size: 0.88rem;
			color: rgba(244, 239, 231, 0.65);
			line-height: 1.4;
		}

		/* ── Funnel ── */
		.funnel {
			margin: 28px 0;
			border-radius: 20px;
			overflow: hidden;
			border: 1px solid rgba(31, 35, 48, 0.08);
		}

		.funnel-row {
			display: flex;
			align-items: center;
			gap: 18px;
			padding: 18px 22px;
			background: var(--panel-strong);
			border-bottom: 1px solid rgba(31, 35, 48, 0.06);
		}

		.funnel-row:last-child {
			border-bottom: none;
			background: var(--text);
		}

		.funnel-row:last-child .funnel-label strong { color: #f4efe7; }
		.funnel-row:last-child .funnel-label span { color: rgba(244, 239, 231, 0.55); }
		.funnel-row:last-child .funnel-val .big { color: #f4efe7; }
		.funnel-row:last-child .funnel-val .sub { color: rgba(244, 239, 231, 0.55); }

		.funnel-arrow-row {
			display: flex;
			align-items: center;
			gap: 10px;
			padding: 8px 22px;
			background: rgba(31, 35, 48, 0.03);
			border-bottom: 1px solid rgba(31, 35, 48, 0.06);
		}

		.funnel-arrow-row span {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.78rem;
			color: var(--muted);
		}

		.funnel-label { flex: 1; }

		.funnel-label strong {
			display: block;
			font-size: 0.94rem;
			font-weight: 600;
			color: var(--text);
			margin-bottom: 2px;
		}

		.funnel-label span {
			font-size: 0.82rem;
			color: var(--muted);
		}

		.funnel-val { text-align: right; flex-shrink: 0; }

		.funnel-val .big {
			font-size: 1.5rem;
			font-weight: 700;
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			display: block;
			color: var(--text);
		}

		.funnel-val .sub {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.7rem;
			color: var(--muted);
			letter-spacing: 0.04em;
		}

		/* ── Flow steps ── */
		.flow-steps { margin: 32px 0; }

		.flow-step {
			display: flex;
			gap: 22px;
			position: relative;
		}

		.flow-step:not(:last-child)::after {
			content: '';
			position: absolute;
			left: 18px;
			top: 42px;
			bottom: -14px;
			width: 2px;
			background: rgba(31, 35, 48, 0.1);
		}

		.flow-num {
			width: 38px;
			height: 38px;
			border-radius: 50%;
			background: var(--text);
			color: #f4efe7;
			display: flex;
			align-items: center;
			justify-content: center;
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.82rem;
			font-weight: 700;
			flex-shrink: 0;
			position: relative;
			z-index: 1;
		}

		.flow-num.accent { background: var(--accent); }

		.flow-body {
			flex: 1;
			padding-bottom: 28px;
		}

		.flow-body h4 {
			font-size: 1.08rem;
			margin: 8px 0 6px;
			color: var(--text);
		}

		.flow-body p {
			font-size: 0.92rem;
			color: var(--muted);
			margin: 0;
			line-height: 1.6;
		}

		/* ── Partner table ── */
		.partner-table {
			width: 100%;
			border-collapse: collapse;
			margin: 24px 0;
			font-size: 0.9rem;
		}

		.partner-table th {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.68rem;
			letter-spacing: 0.09em;
			text-transform: uppercase;
			color: var(--muted);
			text-align: left;
			padding: 10px 14px;
			border-bottom: 2px solid rgba(31, 35, 48, 0.1);
		}

		.partner-table td {
			padding: 14px;
			border-bottom: 1px solid rgba(31, 35, 48, 0.06);
			color: var(--muted);
			vertical-align: top;
			line-height: 1.5;
		}

		.partner-table td strong { color: var(--text); }

		.partner-table tr:last-child td { border-bottom: none; }

		.partner-table tr:hover td {
			background: rgba(255, 251, 245, 0.7);
		}

		.badge {
			display: inline-block;
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.68rem;
			padding: 3px 8px;
			border-radius: 999px;
			letter-spacing: 0.04em;
		}

		.badge-hi { background: rgba(12, 124, 120, 0.14); color: var(--accent-strong); }
		.badge-md { background: rgba(181, 98, 10, 0.14); color: #7a4006; }
		.badge-lo { background: rgba(31, 35, 48, 0.08); color: var(--muted); }

		/* ── Revenue cards ── */
		.rev-card {
			background: var(--panel-strong);
			border: 1px solid rgba(31, 35, 48, 0.08);
			border-radius: 20px;
			padding: 26px;
			margin-bottom: 14px;
			display: grid;
			grid-template-columns: 1fr auto;
			gap: 16px;
			align-items: start;
		}

		.rev-card h4 {
			font-size: 1.12rem;
			margin: 0 0 6px;
			color: var(--text);
		}

		.rev-card p {
			font-size: 0.88rem;
			color: var(--muted);
			margin: 0;
			line-height: 1.55;
		}

		.rev-est { text-align: right; }

		.rev-est .amount {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 1.5rem;
			font-weight: 700;
			color: var(--accent);
			display: block;
		}

		.rev-est .freq {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.7rem;
			color: var(--muted);
			letter-spacing: 0.04em;
		}

		/* ── Metrics ── */
		.metric-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 16px;
			margin: 28px 0;
		}

		.metric-item {
			background: var(--panel-strong);
			border: 1px solid rgba(31, 35, 48, 0.08);
			border-radius: 20px;
			padding: 20px 22px;
		}

		.metric-item h4 {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.72rem;
			text-transform: uppercase;
			letter-spacing: 0.09em;
			color: var(--accent-strong);
			margin: 0 0 12px;
		}

		.metric-item ul {
			list-style: none;
			padding: 0;
			margin: 0;
			display: grid;
			gap: 8px;
		}

		.metric-item ul li {
			font-size: 0.88rem;
			color: var(--muted);
			padding-left: 16px;
			position: relative;
			line-height: 1.55;
			margin-bottom: 14px;
		}

		.metric-item ul li:last-child { margin-bottom: 0; }

		.metric-item ul li::before {
			content: '';
			position: absolute;
			left: 0;
			top: 0.45em;
			width: 6px;
			height: 6px;
			border-radius: 50%;
			background: var(--accent);
		}

		.metric-explain {
			display: block;
			font-size: 0.78rem;
			font-style: italic;
			color: rgba(91, 92, 111, 0.75);
			margin-top: 4px;
			line-height: 1.5;
		}

		/* ── Risks ── */
		.risk-item {
			display: flex;
			gap: 18px;
			padding: 18px 0;
			border-bottom: 1px solid rgba(31, 35, 48, 0.07);
			align-items: start;
		}

		.risk-item:last-child { border-bottom: none; }

		.risk-sev {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.7rem;
			padding: 4px 10px;
			border-radius: 999px;
			flex-shrink: 0;
			margin-top: 3px;
		}

		.risk-content h4 {
			font-size: 0.96rem;
			font-weight: 600;
			color: var(--text);
			margin: 0 0 5px;
		}

		.risk-content p {
			font-size: 0.88rem;
			color: var(--muted);
			margin: 0;
			line-height: 1.55;
		}

		/* ── Conclusion band ── */
		.cs-conclusion {
			background: var(--text);
			color: #f4efe7;
			border-radius: var(--radius-lg);
			padding: 52px 40px;
			margin-top: 0;
		}

		.cs-conclusion .cs-section-num { color: rgba(244, 239, 231, 0.38); }

		.cs-conclusion h2 {
			font-size: clamp(2rem, 4vw, 3.4rem);
			line-height: 0.98;
			letter-spacing: -0.03em;
			margin: 0 0 24px;
			color: #f4efe7;
		}

		.cs-conclusion p {
			color: rgba(244, 239, 231, 0.6);
			font-size: 1.02rem;
			line-height: 1.72;
			margin: 0 0 18px;
		}

		.conclusion-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 20px;
			margin: 36px 0 20px;
		}

		.conclusion-point {
			border-top: 1px solid rgba(244, 239, 231, 0.12);
			padding-top: 18px;
		}

		.conclusion-point h4 {
			font-size: 1.05rem;
			color: #f4efe7;
			margin: 0 0 8px;
		}

		.conclusion-point p {
			font-size: 0.88rem;
			color: rgba(244, 239, 231, 0.55);
			margin: 0;
		}

		.cs-disclaimer {
			font-size: 0.78rem !important;
			color: rgba(244, 239, 231, 0.35) !important;
			border-top: 1px solid rgba(244, 239, 231, 0.1);
			padding-top: 16px;
			margin-top: 8px !important;
		}

		/* ── Footer ── */
		.cs-footer {
			padding: 24px 0;
			display: flex;
			justify-content: space-between;
			align-items: center;
			border-top: 1px solid rgba(31, 35, 48, 0.1);
		}

		.cs-footer span {
			font-family: 'Trebuchet MS', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
			font-size: 0.8rem;
			color: var(--muted);
		}

		/* ── Responsive ── */
		@media (max-width: 800px) {
			.cs-section { padding: 36px 24px; }
			.cs-hero { padding: 36px 24px 32px; }
			.card-grid-3, .stat-row, .metric-grid, .conclusion-grid { grid-template-columns: 1fr; }
			.persona { grid-template-columns: 1fr; }
			.rev-card { grid-template-columns: 1fr; }
			.cs-conclusion { padding: 36px 24px; }
		}

		@media (max-width: 640px) {
			.cs-shell { padding: 16px; }
			.cs-topbar { position: static; }
			.cs-nav { display: none; }
			.card-grid-2 { grid-template-columns: 1fr; }
		}
	</style>

	<div class="cs-shell">
		<div class="ambient ambient-left"></div>
		<div class="ambient ambient-right"></div>

		<!-- Topbar -->
		<header class="cs-topbar">
			<a class="cs-brand" href="/">Vikram Thalithaje</a>
			<nav class="cs-nav" aria-label="Case study sections">
				<a href="#problem">Problem</a>
				<a href="#users">Users</a>
				<a href="#market">Market</a>
				<a href="#solution">Solution</a>
				<a href="#revenue">Revenue</a>
				<a href="#metrics">Metrics</a>
			</nav>
			<a class="cs-back" href="/#case-studies">← Back to portfolio</a>
		</header>

		<main style="display: grid; gap: 20px;">

			<!-- Hero -->
			<section class="cs-hero panel">
				<p class="cs-hero-tag">Product Case Study · Rendin × Moving Services</p>
				<h1>The gap after<br><em>the signature</em></h1>
				<p class="cs-hero-sub">
					A product opportunity analysis on how Rendin — Estonia's rental protection platform — could close
					the tenant journey at the moment it currently stops: the day the contract is signed.
				</p>
				<div class="cs-meta">
					<div class="cs-meta-item">
						<span class="cs-meta-label">Company</span>
						<span class="cs-meta-value">Rendin OÜ, Tallinn</span>
					</div>
					<div class="cs-meta-item">
						<span class="cs-meta-label">Founded</span>
						<span class="cs-meta-value">2019 · Pre-Series A</span>
					</div>
